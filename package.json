{
  "name": "playwright-bdd-automation",
  "version": "1.0.0",
  "description": "Enterprise-grade E2E Automation Framework using Playwright, TypeScript, BDD, and Allure",
  "scripts": {
    "test": "npx cucumber-js",
    "test:ui": "npx cucumber-js --tags @ui",
    "test:api": "npx cucumber-js --tags @api",
    "test:smoke": "npx cucumber-js --tags @smoke",
    "test:regression": "npx cucumber-js --tags @regression",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "npm run allure:generate && npm run allure:open",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf allure-results allure-report"
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.43.1",
    "allure-cucumberjs": "^3.0.0",
    "allure-js-commons": "^3.0.0",
    "playwright": "^1.43.1"
  },
  "devDependencies": {
    "@cucumber/pretty-formatter": "^1.0.1",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "allure-commandline": "^2.27.0"
  }
}
